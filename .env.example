# --- App ---
ENV=development
LOG_LEVEL=INFO
PUBLIC_BASE_URL=https://your-tunnel.ngrok.app
MAX_CONCURRENT_CALLS=10

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT_S=30
ANTHROPIC_MAX_RETRIES=3

# --- Deepgram (STT) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
DEEPGRAM_ENDPOINTING_MS=300

# --- ElevenLabs (TTS) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_TIMEOUT_S=30

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...
# Set to "false" only for local curl testing. Always "true" in production.
TWILIO_VALIDATE_SIGNATURE=true

# --- Storage ---
DATABASE_URL=postgresql+asyncpg://voice:voice@db:5432/voice
REDIS_URL=redis://redis:6379/0
