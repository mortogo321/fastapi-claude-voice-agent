# Staging template.
#
# Secrets MUST come from the environment (CI/CD, Secrets Manager, etc.).
# Non-secret tunables keep sensible fallbacks so the file is self-contained.
# Missing secrets are tolerated on startup (fail-fast only runs in prod) so
# staging can still boot with a subset of integrations.

# --- App ---
ENV=staging
LOG_LEVEL=${LOG_LEVEL:-INFO}
PUBLIC_BASE_URL=${PUBLIC_BASE_URL:-https://staging.example.com}
MAX_CONCURRENT_CALLS=${MAX_CONCURRENT_CALLS:-25}

# --- Anthropic ---
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
ANTHROPIC_MODEL=${ANTHROPIC_MODEL:-claude-opus-4-7}
ANTHROPIC_MAX_TOKENS=${ANTHROPIC_MAX_TOKENS:-1024}
ANTHROPIC_TIMEOUT_S=${ANTHROPIC_TIMEOUT_S:-30}
ANTHROPIC_MAX_RETRIES=${ANTHROPIC_MAX_RETRIES:-3}

# --- Deepgram (STT) ---
DEEPGRAM_API_KEY=${DEEPGRAM_API_KEY:-}
DEEPGRAM_MODEL=${DEEPGRAM_MODEL:-nova-3}
DEEPGRAM_LANGUAGE=${DEEPGRAM_LANGUAGE:-multi}
DEEPGRAM_ENDPOINTING_MS=${DEEPGRAM_ENDPOINTING_MS:-300}

# --- ElevenLabs (TTS) ---
ELEVENLABS_API_KEY=${ELEVENLABS_API_KEY:-}
ELEVENLABS_VOICE_ID=${ELEVENLABS_VOICE_ID:-21m00Tcm4TlvDq8ikWAM}
ELEVENLABS_MODEL=${ELEVENLABS_MODEL:-eleven_turbo_v2_5}
ELEVENLABS_TIMEOUT_S=${ELEVENLABS_TIMEOUT_S:-30}

# --- Twilio ---
TWILIO_ACCOUNT_SID=${TWILIO_ACCOUNT_SID:-}
TWILIO_AUTH_TOKEN=${TWILIO_AUTH_TOKEN:-}
TWILIO_FROM_NUMBER=${TWILIO_FROM_NUMBER:-}
TWILIO_VALIDATE_SIGNATURE=${TWILIO_VALIDATE_SIGNATURE:-true}

# --- Storage ---
DATABASE_URL=${DATABASE_URL:-postgresql+asyncpg://voice:voice@db:5432/voice}
REDIS_URL=${REDIS_URL:-redis://redis:6379/0}
